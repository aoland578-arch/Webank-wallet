# Copy to .env on the CVM and replace every placeholder before starting.

# Use a long random value. Do not reuse the local development value.
WEWALLET_AUTH_SECRET=replace-with-64-random-chars

# Set to 1 only when temporarily debugging SMS codes in logs.
WEWALLET_SMS_DEBUG=0

# Keep Secure cookies enabled when the site is served over HTTPS.
WEWALLET_COOKIE_SECURE=1

# Optional tuning.
CUSTOMER_MANAGER_KB_TOP_K=5

# DashScope (Aliyun) API key for the per-enterprise image history KB.
# Each enterprise builds its own history from images the client uploads
# during chat (stored under app_data/enterprises/<id>/image_kb/).
# Get a key at https://dashscope.console.aliyun.com/. Leave empty to disable.
DASHSCOPE_API_KEY=
# Image-query threshold ~0.55 (similarity to history images), text-query
# threshold ~0.45 (text-to-history image similarity). Below threshold ⇒
# no recall, which keeps spurious "前后矛盾" prompts out.
CUSTOMER_MANAGER_IMG_KB_IMG_THRESHOLD=0.55
CUSTOMER_MANAGER_IMG_KB_TXT_THRESHOLD=0.45
CUSTOMER_MANAGER_IMG_KB_TOP_K=3

# ── 视频通话模块（通话版小微的大脑）──
# 默认走火山方舟 Ark Doubao；填 ARK_API_KEY 即可。
ARK_API_KEY=
# 想改用阶跃星辰 StepFun（OpenAI 兼容，step-3.7-flash 多模态）：
# 填 STEP_API_KEY 并把 provider 设为 stepfun。key 在 https://platform.stepfun.com 申请。
STEP_API_KEY=
WEWALLET_VOICECALL_PROVIDER=ark
# 通话语音后端：realtime=端到端实时语音 stepaudio-2.5-realtime（需 STEP_API_KEY，
# 启动时自动起 WS 中继）；placeholder=浏览器原生 STT/TTS 占位。缺 key 会自动回落。
WEWALLET_VOICECALL_VOICE_BACKEND=realtime
WEWALLET_STEP_REALTIME_VOICE=jingdiannvsheng
# 中继端口（浏览器连它，它替你加 Bearer key 连 StepFun）。
WEWALLET_VOICECALL_RELAY_PORT=8789
# 生产（nginx 反代）推荐：同源路径，nginx 把它反代到中继；前端按页面协议自动 ws/wss。
# docker 部署已在 compose 里设好这个 + RELAY_HOST=0.0.0.0，本地开发留空即可。
WEWALLET_VOICECALL_RELAY_PATH=
# 或给完整地址覆盖（跨域才用），如 wss://your-host/voicecall-relay。
WEWALLET_VOICECALL_RELAY_PUBLIC_URL=
# 中继访问令牌：留空则每次启动随机生成（够用）。中继靠它挡公网盗用你的 STEP_API_KEY，
# 登录后的前端从 /api/voicecall/realtime-config 自动领取。
WEWALLET_VOICECALL_RELAY_TOKEN=
